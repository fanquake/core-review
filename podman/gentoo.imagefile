FROM docker.io/gentoo/stage3

RUN emerge-webrsync && emerge --sync && emerge \
    boost \
    capnproto \
    ccache \
    cmake \
    gcc \
    dev-vcs/git \
    dev-db/sqlite \
    vim \
    zeromq

RUN git clone https://github.com/bitcoin/bitcoin && mkdir bitcoin/depends/SDKs

RUN make download -C bitcoin/depends

WORKDIR /bitcoin
